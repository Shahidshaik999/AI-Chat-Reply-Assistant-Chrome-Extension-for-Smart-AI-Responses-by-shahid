{
  "manifest_version": 3,
  "name": "AI Chat Reply Assistant",
  "version": "2.0.3",
  "description": "Generate smart AI-powered reply suggestions for WhatsApp and LinkedIn chats",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://web.whatsapp.com/*",
    "https://www.linkedin.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://web.whatsapp.com/*",
        "https://www.linkedin.com/*"
      ],
      "js": ["contentScript.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "AI Chat Assistant - Click to analyze current chat"
  }
}
